    {
        "id": "84668f378c4cd992",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "Stop counter (0->1)",
        "func": "let prev = flow.get(\"prevStopped_count\");\nlet count = flow.get(\"stopCount\") || 0;\n\nif (prev === undefined) {\n  flow.set(\"prevStopped_count\", msg.isStopped);\n  msg.payload = count;\n  return msg;\n}\n\nif (prev === false && msg.isStopped === true) {\n  count += 1;\n  flow.set(\"stopCount\", count);\n}\n\nflow.set(\"prevStopped_count\", msg.isStopped);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 690,
        "y": 110,
        "wires": [
