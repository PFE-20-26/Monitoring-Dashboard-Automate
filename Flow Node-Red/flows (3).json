    {
        "id": "2a1c5e9598d94f55",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "Edge detect -> SQL INSERT/UPDATE (with equipe)",
        "func": "function pad2(n){ return (n<10?\"0\":\"\") + n; }\nfunction ts(d){\n  return d.getFullYear()+\"-\"+pad2(d.getMonth()+1)+\"-\"+pad2(d.getDate())+\" \"+pad2(d.getHours())+\":\"+pad2(d.getMinutes())+\":\"+pad2(d.getSeconds());\n}\nfunction equipeFromDate(d){\n  const h = d.getHours();\n  if (h >= 6 && h < 14) return 1;     // 06:00 -> 13:59\n  if (h >= 14 && h < 22) return 2;    // 14:00 -> 21:59\n  return 3;                            // 22:00 -> 05:59\n}\n\nlet prev = flow.get(\"prevStopped_sql\");\n\n// init: avoid fake event after deploy\nif (prev === undefined) {\n  flow.set(\"prevStopped_sql\", msg.isStopped);\n  return [null, null];\n}\n\nlet outInsert = null;\nlet outUpdate = null;\n\n// RUN -> STOP : INSERT start_time + equipe\nif (prev === false && msg.isStopped === true) {\n  const now = new Date();\n  const startTime = ts(now);\n  const equipe = equipeFromDate(now);\n\n  outInsert = {\n    topic: \"INSERT INTO stop_events (start_time, equipe) VALUES (?, ?)\",\n    payload: [startTime, equipe]\n  };\n}\n\n// STOP -> RUN : UPDATE end_time + cause (close last open record)\nif (prev === true && msg.isStopped === false) {\n  const endTime = ts(new Date());\n\n  const causeRaw = flow.get(\"currentCause\");\n  const cause = (typeof causeRaw === \"string\" && causeRaw.trim().length)\n    ? causeRaw.trim()\n    : \"Unknown\";\n\n  outUpdate = {\n    topic: \"UPDATE stop_events SET end_time = ?, cause = ? WHERE end_time IS NULL ORDER BY id DESC LIMIT 1\",\n    payload: [endTime, cause]\n  };\n}\n\nflow.set(\"prevStopped_sql\", msg.isStopped);\nreturn [outInsert, outUpdate];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 550,
        "y": 200,
        "wires": [
            [
                "06f71839cddcf17e"
            ],
            [
                "a4da44695853d8c9"
            ]
        ]
    },
