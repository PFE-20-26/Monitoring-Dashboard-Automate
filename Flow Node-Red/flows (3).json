        "id": "8280035148422120",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "Store current cause",
        "func": "const cause = (typeof msg.payload === \"string\") ? msg.payload.trim() : String(msg.payload);\nflow.set(\"currentCause\", cause);\nreturn null;",
        "outputs": 1,
