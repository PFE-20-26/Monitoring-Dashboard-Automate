    {
        "id": "68348d8205f39344",
        "type": "ui_template",
        "z": "5f63f24b9e84d865",
        "group": "18c82ffc2545d602",
        "name": "Stop History (from MySQL)",
        "order": 2,
        "width": 0,
        "height": 0,
        "format": "<div style=\"padding:0 6px;\">\n  <div ng-if=\"!msg.payload || msg.payload.length === 0\" style=\"color:#888;\">\n    No stops in database yet.\n  </div>\n\n  <table ng-if=\"msg.payload && msg.payload.length\" style=\"width:100%; border-collapse:collapse;\">\n    <thead>\n      <tr>\n        <th style=\"text-align:left; border-bottom:1px solid #ccc; padding:4px;\">Stop start time</th>\n        <th style=\"text-align:left; border-bottom:1px solid #ccc; padding:4px;\">Stop end time</th>\n        <th style=\"text-align:left; border-bottom:1px solid #ccc; padding:4px;\">Cause d’arrêt</th>\n        <th style=\"text-align:left; border-bottom:1px solid #ccc; padding:4px;\">Equipe</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr ng-repeat=\"row in msg.payload track by row.id\">\n        <td style=\"padding:4px; border-bottom:1px solid #eee;\">{{row.start_time}}</td>\n        <td style=\"padding:4px; border-bottom:1px solid #eee;\">{{row.end_time || '—'}}</td>\n        <td style=\"padding:4px; border-bottom:1px solid #eee;\">{{row.cause || '—'}}</td>\n        <td style=\"padding:4px; border-bottom:1px solid #eee;\">{{row.equipe || '—'}}</td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
