    {
        "id": "05389185c2b24f57",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "Extract isStopped boolean",
        "func": "let v;\n\nif (msg.payload && msg.payload.data && Array.isArray(msg.payload.data)) {\n  v = msg.payload.data[0];\n} else if (Array.isArray(msg.payload)) {\n  v = msg.payload[0];\n} else {\n  v = msg.payload;\n}\n\nmsg.isStopped = (v === true) || (v === 1);\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 120,
        "wires": [
