    {
        "id": "a2afe375e9a073a1",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "SELECT last rows (with equipe label)",
        "func": "msg.topic = \"SELECT\\n\" +\n            \"  id,\\n\" +\n            \"  DATE_FORMAT(start_time, '%Y-%m-%d %H:%i:%s') AS start_time,\\n\" +\n            \"  DATE_FORMAT(end_time,   '%Y-%m-%d %H:%i:%s') AS end_time,\\n\" +\n            \"  cause,\\n\" +\n            \"  CASE equipe\\n\" +\n            \"    WHEN 1 THEN 'Equipe 1'\\n\" +\n            \"    WHEN 2 THEN 'Equipe 2'\\n\" +\n            \"    WHEN 3 THEN 'Equipe 3'\\n\" +\n            \"    ELSE CONCAT('Equipe ', equipe)\\n\" +\n            \"  END AS equipe\\n\" +\n            \"FROM stop_events\\n\" +\n            \"ORDER BY id DESC\\n\" +\n            \"LIMIT 50\";\nmsg.payload = [];\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
