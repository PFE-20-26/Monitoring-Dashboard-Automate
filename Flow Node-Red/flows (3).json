        "id": "feb42870bb1787cf",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "Format -> ui_chart (bar)",
        "func": "// MySQL node returns an array of rows: [{cause: 'X', stop_count: 5}, ...]\nconst rows = msg.payload;\n\nconst labels = [];\nconst data = [];\n\nif (Array.isArray(rows)) {\n  rows.forEach(r => {\n    labels.push(String(r.cause));\n    data.push(Number(r.stop_count));\n  });\n}\n\n// ui_chart expects: [{ series: [..], data: [[..]], labels: [..] }]\nmsg.payload = [{\n  series: [\"Stops\"],\n  data: [data],\n  labels: labels\n}];\n\nreturn msg;",
