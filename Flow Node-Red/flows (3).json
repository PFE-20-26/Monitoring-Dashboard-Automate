    {
        "id": "b59bea7d3162c341",
        "type": "function",
        "z": "5f63f24b9e84d865",
        "name": "SQL: stop count per cause (Top 10)",
        "func": "msg.topic = \"SELECT \" +\n            \"  IFNULL(NULLIF(TRIM(cause), ''), 'Unknown') AS cause, \" +\n            \"  COUNT(*) AS stop_count \" +\n            \"FROM stop_events \" +\n            \"WHERE end_time IS NOT NULL \" +\n            \"GROUP BY IFNULL(NULLIF(TRIM(cause), ''), 'Unknown') \" +\n            \"ORDER BY stop_count DESC \" +\n            \"LIMIT 10\";\n\nmsg.payload = [];\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
