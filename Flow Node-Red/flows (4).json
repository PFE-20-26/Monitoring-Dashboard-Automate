    {
        "id": "8557cfee3827e10c",
        "type": "function",
        "z": "7f3e086f86256379",
        "name": "Build SQL  (cause_id vient de D30)",
        "func": "// ─── Registres lus : D10..D30 (qty=21) ─────────────────────\n// idx 0..6   = D10..D16  Start TRD\n// idx 7..9   = D17..D19  (non utilisés)\n// idx 10..16 = D20..D26  Stop TRD\n// idx 17..19 = D27..D29  (non utilisés)\n// idx 20     = D30       cause_id écrit par le ladder ISPSoft\n\nconst MICRO_STOP_SEC = 30;\nconst NC_CAUSE_ID    = 16;\n\nlet regs = null;\nconst p = msg.payload;\nif (p && Array.isArray(p.data))         regs = p.data;\nelse if (Array.isArray(p))              regs = p;\nelse if (p && Array.isArray(p.payload)) regs = p.payload;\n\nif (!regs || regs.length < 21) {\n  node.error(`Expected 21 regs, got ${regs ? regs.length : 0}`, msg);\n  return null;\n}\n\nfunction pad2(n) { return String(n).padStart(2, '0'); }\n\n// Start TRD D10..D16\nconst y1  = Number(regs[0]);\nconst mo1 = Number(regs[2]);\nconst d1  = Number(regs[3]);\nconst h1  = Number(regs[4]);\nconst mi1 = Number(regs[5]);\nconst s1  = Number(regs[6]);\n\n// Stop TRD D20..D26\nconst y2  = Number(regs[10]);\nconst mo2 = Number(regs[12]);\nconst d2  = Number(regs[13]);\nconst h2  = Number(regs[14]);\nconst mi2 = Number(regs[15]);\nconst s2  = Number(regs[16]);\n\n// ✅ cause_id depuis D30 (écrit par ISPSoft selon le M bit actif)\nconst plcCauseId = Number(regs[20]) || 0;\n\nconst jour  = `${y1}-${pad2(mo1)}-${pad2(d1)}`;\nconst debut = `${pad2(h1)}:${pad2(mi1)}:${pad2(s1)}`;\nconst fin   = `${pad2(h2)}:${pad2(mi2)}:${pad2(s2)}`;\n\nconst startMs = Date.UTC(y1, mo1-1, d1, h1, mi1, s1);\nconst stopMs  = Date.UTC(y2, mo2-1, d2, h2, mi2, s2);\n\nif (!Number.isFinite(startMs) || !Number.isFinite(stopMs) || stopMs < startMs) {\n  node.error(`Bad timestamps: ${jour} ${debut} → ${fin}`, msg);\n  return null;\n}\n\nconst durationSec = Math.floor((stopMs - startMs) / 1000);\n\n// Micro-arrêt < 30s → NC(16), sinon cause du PLC D30\nconst cause_id = durationSec < MICRO_STOP_SEC ? NC_CAUSE_ID : (plcCauseId || 1);\n\nmsg.stopKey = `${jour} ${debut}|${fin}`;\nmsg.stop    = { jour, debut, fin, durationSec, cause_id, plcCauseId };\n\nmsg.topic   = 'INSERT INTO stops (`Jour`, `Debut`, `Fin`, `cause_id`) VALUES (?, ?, ?, ?)';\nmsg.payload = [jour, debut, fin, cause_id];\n\nnode.log(`INSERT: ${jour} ${debut}→${fin} | ${durationSec}s | cause_id=${cause_id} (D30=${plcCauseId})`);\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 300,
        "wires": [
