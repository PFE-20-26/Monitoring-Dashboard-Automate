    {
        "id": "136163c56de1c695",
        "type": "function",
        "z": "2c5dc8e60bfa2009",
        "name": "Extract stopReady boolean",
        "func": "let bits = null;\nif (msg.payload && Array.isArray(msg.payload.data)) bits = msg.payload.data;\nelse if (Array.isArray(msg.payload)) bits = msg.payload;\nelse if (msg.payload && Array.isArray(msg.payload.payload)) bits = msg.payload.payload;\n\nif (!bits || bits.length === 0) return null;\n\nconst v = bits[0];\nconst stopReady = (v === true || v === 1 || v === '1');\nmsg.payload = stopReady;\nmsg.stopReady = stopReady;\nreturn msg;\n",
        "outputs": 1,
        "noerr": 0,
