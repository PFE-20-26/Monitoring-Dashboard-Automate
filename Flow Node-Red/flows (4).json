    {
        "id": "3d7203982ff54e2a",
        "type": "function",
        "z": "2c5dc8e60bfa2009",
        "name": "Build SQL — correct columns (Jour/Début/Fin)",
        "func": "const MICRO_STOP_SEC = 30;\nconst DEFAULT_CAUSE_ID = 1;   // cause_id par défaut (modifiable)\nconst NC_CAUSE_ID      = 16;  // cause_id micro-arrêt NC\n\nlet regs = null;\nconst p = msg.payload;\nif (p && Array.isArray(p.data))         regs = p.data;\nelse if (Array.isArray(p))              regs = p;\nelse if (p && Array.isArray(p.payload)) regs = p.payload;\n\nif (!regs || regs.length < 17) {\n  node.error('Expected 17 regs (D10..D26)', msg);\n  return null;\n}\n\nfunction pad2(n) { return String(n).padStart(2, '0'); }\n\n// Start TRD : D10..D16 => idx 0..6\nconst y1  = Number(regs[0]);\nconst mo1 = Number(regs[2]);\nconst d1  = Number(regs[3]);\nconst h1  = Number(regs[4]);\nconst mi1 = Number(regs[5]);\nconst s1  = Number(regs[6]);\n\n// Stop TRD : D20..D26 => idx 10..16\nconst y2  = Number(regs[10]);\nconst mo2 = Number(regs[12]);\nconst d2  = Number(regs[13]);\nconst h2  = Number(regs[14]);\nconst mi2 = Number(regs[15]);\nconst s2  = Number(regs[16]);\n\n// ✅ Jour = DATE  (YYYY-MM-DD)\nconst jour  = `${y1}-${pad2(mo1)}-${pad2(d1)}`;\n\n// ✅ Début = TIME (HH:mm:ss)\nconst debut = `${pad2(h1)}:${pad2(mi1)}:${pad2(s1)}`;\n\n// ✅ Fin = TIME   (HH:mm:ss)\nconst fin   = `${pad2(h2)}:${pad2(mi2)}:${pad2(s2)}`;\n\n// Validation\nconst startMs = Date.UTC(y1, mo1-1, d1, h1, mi1, s1);\nconst stopMs  = Date.UTC(y2, mo2-1, d2, h2, mi2, s2);\n\nif (!Number.isFinite(startMs) || !Number.isFinite(stopMs) || stopMs < startMs) {\n  node.error(`Bad timestamps: start=${jour} ${debut} stop=${fin}`, msg);\n  return null;\n}\n\nconst durationSec = Math.floor((stopMs - startMs) / 1000);\n\n// Micro-arrêt < 30s → cause NC(16), sinon défaut(1)\nconst cause_id = durationSec < MICRO_STOP_SEC ? NC_CAUSE_ID : DEFAULT_CAUSE_ID;\n\nmsg.stopKey = `${jour} ${debut}|${fin}`;\nmsg.stop    = { jour, debut, fin, durationSec, cause_id };\n\n// ✅ INSERT avec les vrais noms de colonnes de ta DB\nmsg.topic   = 'INSERT INTO stops (`Jour`, `Debut`, `Fin`, `cause_id`) VALUES (?, ?, ?, ?)';\nmsg.payload = [jour, debut, fin, cause_id];\n\nnode.log(`INSERT: ${jour} ${debut} → ${fin} (${durationSec}s) cause_id=${cause_id}`);\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
